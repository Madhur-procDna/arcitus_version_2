# Copy to deployment.env and adjust (this file is safe to commit; not read for secrets).

# ── Published Nginx ports (host → container :80 / :443) ───────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Nginx site config inside the repo (HTTP default — use behind AWS ALB with TLS too)
NGINX_CONF_PATH=./nginx/nginx.conf

# For TLS terminating ON the EC2 box (pem files in deploy/certs/):
#   NGINX_CONF_PATH=./nginx/nginx.https.conf
#   docker compose --env-file .env --env-file deployment.env \
#     -f docker-compose.yml -f docker-compose.https.yml up -d --build
