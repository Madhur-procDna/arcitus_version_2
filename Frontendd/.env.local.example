# Copy to .env.local (do not commit .env.local)
#
# Dev default: browser calls same-origin /api/query; Next.js proxies to Python (no CORS issues).
# Point this at your FastAPI app — port must match uvicorn (8000 is common for manual runs).
SDA_BACKEND_URL=http://127.0.0.1:8000
# Shared key sent by Next.js proxy to backend `/query` (`X-API-Key` header)
# Must match Backend `SDA_BACKEND_API_KEY`.
# SDA_BACKEND_API_KEY=change-me
#
# Server-side login credentials (used by `/api/auth/login` route)
# SDA_AUTH_USERNAME=admin
# SDA_AUTH_PASSWORD=change-me
# SDA_AUTH_SECRET=change-me-long-random-string
#
# Optional: call FastAPI directly from the browser (requires CORS on API).
# Use the API origin only — POST /query (do not add /api):
# NEXT_PUBLIC_SERVER_URL=http://127.0.0.1:8000
#
# Long NL→SQL runs (default 600s browser + proxy). Increase if you still see "read timed out":
# NEXT_PUBLIC_QUERY_FETCH_TIMEOUT_MS=600000
# SDA_QUERY_PROXY_TIMEOUT_MS=600000
