# Copy to .env and fill in. Never commit .env.

# ── Arcetus / Excel sample (no Postgres) ────────────────────────────────────
# Default: ``sda_data_source=sqlite`` loads one workbook into in-memory SQLite at API startup.
# Put ``Arcutis Dummy Data v1.xlsx`` under ``Backend/data/`` or set an absolute path:
# SDA_DATA_SOURCE=sqlite
# DATA_FILE_PATH=C:\path\to\Arcutis Dummy Data v1.xlsx
# To use Postgres again instead of the workbook:
# SDA_DATA_SOURCE=postgres
#
# SQLite workbook — multi-step pharma agent (default on). Set 0 to use legacy single-shot NL→SQL instead.
# SDA_SQL_AGENT=1
# SDA_AGENT_MAX_ITER=4
# When the model returns several SELECTs in one string, keep the first (SQLite only). Set ``reject`` to disable.
# SDA_SQLITE_MULTI_STATEMENT_POLICY=first_select
#
# Chat body: hide ```sql``` / fenced SELECT from the ``response`` text (SQL still in JSON ``sql``). Set 1 to show SQL in chat.
# SDA_CHAT_INCLUDE_SQL=0
# Charts: default off unless the rep asks for a chart/graph; set 1 to auto-attach chart payloads for plottable results.
# SDA_AUTO_CHART=0

# Azure OpenAI
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
# Embeddings are used for schema RAG (similar ERD chunks + join paths per question). Set SDA_DISABLE_SCHEMA_RAG=1 to skip.
# SDA_DISABLE_SCHEMA_RAG=0
# SQLite / Arcetus workbook: embed each **loaded table** (columns + row counts) and retrieve top-k per question for the SQL agent.
# Same Azure embeddings deployment as ERD RAG. Index: src/data/workbook_rag_index.json (rebuilt when workbook hash changes).
# SDA_DISABLE_WORKBOOK_RAG=0
# SDA_WORKBOOK_RAG_TOP_K=8
# SDA_WORKBOOK_RAG_MAX_CHARS=16000
# SDA_WORKBOOK_RAG_REBUILD=1
# SDA_SCHEMA_RAG_TOP_K=6
# SCHEMA_RAG_DATA_DIR=        # default: src/data (stores schema_rag_index.json)
# SDA_SCHEMA_RAG_REBUILD=1    # force one-time rebuild after ERD edits (otherwise auto when ERD hash changes)
# SDA_SCHEMA_RAG_MAX_CHARS=28000
# SDA_SCHEMA_RAG_PROMPT_CAP=32000
# Seconds per Azure HTTP call (intent + text-to-SQL + summarize each use one). Default 120; raise if calls timeout.
# AZURE_OPENAI_HTTP_TIMEOUT_SEC=120

# Postgres
PGHOST=
# Seeded by Backend/mock_data.py → e.g. mimic_updatedd_db
PGDATABASE=
PGUSER=
PGPASSWORD=
PGPORT=5432
# Max rows per query when not in unlimited mode (default 5000). Ignored when fetch uses unlimited=True.
# POSTGRES_MAX_ROWS=5000
# Query execution cap in ms (default 60000 in postgres_runner). Very wide NL→SQL joins may need 120000+.
# POSTGRES_STATEMENT_TIMEOUT_MS=120000

# Pipeline: no SQL LIMIT hint, fetch all rows from Postgres, send all rows to the summarizer (use for full exports).
# Also set automatically for open questions like "Which X are most dangerous" (no explicit "top N") — trailing LIMIT is stripped from generated SQL.
# Large result sets can be slow and hit model context limits — use tabular output or export for huge tables.
# SDA_UNLIMITED_RESULTS=false

# Optional schema
PGSCHEMA=

# FastAPI (src/api_server.py): comma-separated origins for Next.js dev server
# CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SQL validation (sql_validate.py): AST parse + security walk. Verbose logs to stdout when true.
# SQLGLOT_VERBOSE=false
# SQLGLOT_VALIDATE=true
# SQLGLOT_DIALECT=postgres
# SQL_MAX_CTE_DEPTH=12

# Markdown ERD used as schema ground truth for every text-to-SQL prompt (default src/ERD.md). Absolute path or path relative to DSA/.
# SDA_ERD_PATH=docs/my_erd.md
# ERD_PATH=../path/to/ERD.md

# If true, skip the \"top/best/performing\" ambiguity stop (always send vague questions to the LLM).
# SDA_SKIP_AMBIGUITY_CHECK=false

# If true, allow one message to contain several ';'-separated asks (default: show clarification — one SQL per turn).
# SDA_ALLOW_COMPOUND_QUESTIONS=false

# If true, disable deterministic hcp_call_plan fast-paths (simple SELECTs + duplicate-name analysis with total_records / unique_ids).
# SDA_DISABLE_HCP_LOOKUP_FASTPATH=false

# Takeda ERD (default): rep_activity + hcp_call_plan in PGSCHEMA (usually public). NL→SQL uses ERD.md only.
# Sofie-only database: set SDA_SOFIE_ONLY=true.
SDA_SOFIE_ONLY=false
SDA_SOFIE_QUERIES_ONLY=false

# Comma-separated schemas for information_schema column dump (default public). Use raw,warehouse only for legacy loads.
# SDA_TAKEDA_DSA_SCHEMAS=public
# SDA_REP_ACTIVITY_SCHEMA=public

# When Sofie is on: if sofie_act_fact is visible, pipeline uses Sofie star path.
# SDA_PREFER_REP_ACTIVITY=false (only when SDA_SOFIE_ONLY=false)

# Postgres schema for qualified names in prompts (see pharma_schema._schema_name)
# PGSCHEMA=public
# SDA_PHARMA_SCHEMA=public
# Legacy alias: SDA_TAKEDA_SCHEMA=public

# Before text-to-SQL, list base tables from information_schema into the prompt (so SQL matches the real DB).
# Set to 0/false/off to skip (e.g. offline tests without Postgres).
# SDA_LIVE_TABLE_NAMES=1

# Redis (optional cache + conversation turns). If REDIS_ENABLED=true (default) and
# REDIS_HOST is empty, the app uses 127.0.0.1. Set REDIS_ENABLED=0 to disable Redis.
REDIS_HOST=
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_ENABLED=true
# TTL (seconds) for Redis QA cache entries (same question → instant answer when not time-volatile).
# REDIS_TTL_SECONDS=900
# Set to 1 to disable answer caching only (conversation Redis still used unless REDIS_ENABLED=0).
# SDA_DISABLE_QA_CACHE=false

# LangSmith (optional tracing)
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=

# Text-to-SQL output budget (optional)
TEXT_TO_SQL_MAX_TOKENS=2048

# Latency tuning (local dev)
# SDA_PIPELINE_FAST=false
# SDA_DISABLE_LANGSMITH=true
# SDA_SUMMARY_MAX_TOKENS=5000
# SDA_SKIP_ERD_APPEND=true
# SDA_SKIP_SQL_PARSE_REGEN=true
